{
  "name": "yaml-frontmatter-bar",
  "displayName": "YAML Front Matter Bar",
  "description": "Displays YAML front matter as a beautiful, styled info bar at the top of Markdown preview.",
  "version": "0.1.0",
  "publisher": "zhangli",
  "author": {
    "name": "zlvb",
    "email": "zlvbvbzl@gmail.com"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zlvb/vscode-yaml-frontmatter-bar.git"
  },
  "bugs": {
    "url": "https://github.com/zlvb/vscode-yaml-frontmatter-bar/issues"
  },
  "homepage": "https://github.com/zlvb/vscode-yaml-frontmatter-bar#readme",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Formatters"
  ],
  "keywords": [
    "yaml",
    "frontmatter",
    "front-matter",
    "markdown",
    "preview",
    "metadata",
    "info-bar",
    "mdc"
  ],
  "galleryBanner": {
    "color": "#1e3a5f",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "markdown.previewStyles": [
      "./media/markdown-preview.css"
    ],
    "markdown.markdownItPlugins": true
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.60.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "yaml": "^2.3.4"
  }
}
